# Copy this file to `.env` and fill in your own values. NEVER commit the real `.env`.
# These are read from the environment by the code; nothing here is required for the
# public GPT-2 model, but a HF token avoids rate limits and unlocks gated datasets.

# Hugging Face access token (https://huggingface.co/settings/tokens).
# Used by transformers / datasets / sae-lens when downloading models, SAEs and corpora.
HF_TOKEN=

# Weights & Biases API key (https://wandb.ai/authorize). Optional — only needed if you
# run training with `--wandb`. Leave blank to disable experiment logging.
WANDB_API_KEY=
